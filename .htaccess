# SPA fallback: send all non-file requests to index.html so client-side routing works.
# Required when users paste or refresh deep links: /en, /en/contact, /id/about/board-of-directors, etc.
# If the site lives in a subfolder, set RewriteBase /subfolder/
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # If the request is not for a real file or directory, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Optional: prevent directory listing
Options -Indexes
